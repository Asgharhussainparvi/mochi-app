# ─── App ───────────────────────────────────────
SECRET_KEY= # Generate with: openssl rand -hex 32
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Database ──────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/mochi_db

# ─── Redis ─────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── OAuth — Google ────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── OAuth — GitHub ────────────────────────────
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Callback base (no trailing slash)
OAUTH_REDIRECT_BASE_URL=http://localhost:8000

# ─── HuggingFace ───────────────────────────────
# Token for downloading genmo/mochi-1-preview
HF_TOKEN=
HF_MODEL_ID=genmo/mochi-1-preview

# ─── Storage ───────────────────────────────────
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/app/storage

# S3 (optional)
# STORAGE_BACKEND=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=mochi-videos
# AWS_REGION=us-east-1

# ─── CORS ──────────────────────────────────────
# ALLOWED_ORIGINS=["http://localhost:3000","https://yourdomain.com"]

# ─── Worker ────────────────────────────────────
MAX_CONCURRENT_JOBS=1
VIDEO_GENERATION_TIMEOUT=600
